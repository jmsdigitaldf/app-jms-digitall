# ===========================
# PRODUCTION Environment Configuration
# ===========================
# Copie este arquivo para .env.production e preencha com seus valores reais

# DATABASE
DATABASE_URL="postgresql://seu_usuario:sua_senha@161.97.111.53:5432/jms_digitall?schema=public"

# JWT Secrets (Gere valores aleatórios fortes!)
JWT_SECRET="gere-uma-chave-aleatoria-com-openssl-ou-similar"
JWT_REFRESH_SECRET="gere-outra-chave-aleatoria-diferente"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# WhatsApp Cloud API (Opcional - configure quando precisar)
WHATSAPP_TOKEN="seu-token-aqui"
WHATSAPP_VERIFY_TOKEN="seu-verify-token"
WHATSAPP_PHONE_ID="seu-phone-id"
WHATSAPP_BUSINESS_ID="seu-business-id"

# OpenAI / AI Provider (Opcional)
OPENAI_API_KEY="sua-chave-openai"

# Server
NODE_ENV="production"
PORT=3000
FRONTEND_URL="https://seu-dominio.com"
CORS_ORIGIN="https://seu-dominio.com,https://www.seu-dominio.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
