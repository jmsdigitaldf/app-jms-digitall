generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(TECHNICIAN)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  avatarUrl     String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  tickets       Ticket[]
  quotes        Quote[]
  refreshTokens RefreshToken[]
  
  @@index([email])
  @@index([role])
}

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIAN
  RECEPTIONIST
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

// ============================================
// CLIENTES
// ============================================

model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  email       String?
  document    String?  // CPF/CNPJ
  address     String?
  city        String?
  state       String?
  zipCode     String?
  notes       String?
  isActive    Boolean  @default(true)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  tickets     Ticket[]
  
  @@index([phone])
  @@index([email])
  @@index([name])
}

// ============================================
// ATENDIMENTOS (TICKETS)
// ============================================

model Ticket {
  id              String      @id @default(uuid())
  protocol        String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  
  // Informações do WhatsApp
  whatsappMessage String
  whatsappMsgId   String?
  aiResponse      String?
  
  // Classificação
  problemType     ProblemType
  problemDetails  String?
  deviceType      DeviceType  @default(LAPTOP)
  deviceBrand     String?
  deviceModel     String?
  
  // Status
  status          TicketStatus @default(PENDING)
  priority        Priority     @default(MEDIUM)
  
  // Técnico responsável
  assignedToId    String?
  assignedTo      User?        @relation(fields: [assignedToId], references: [id])
  
  // Timestamps
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  completedAt     DateTime?
  
  // Relations
  quotes          Quote[]
  statusHistory   TicketStatusHistory[]
  
  @@index([customerId])
  @@index([status])
  @@index([protocol])
  @@index([assignedToId])
}

enum ProblemType {
  SCREEN
  BATTERY
  KEYBOARD
  SLOW_PERFORMANCE
  VIRUS_MALWARE
  HARDWARE
  SOFTWARE
  FORMAT_OS
  DATA_RECOVERY
  NETWORK_WIFI
  AUDIO
  POWER_JACK
  MOTHERBOARD
  COOLING
  OTHER
}

enum DeviceType {
  LAPTOP
  DESKTOP
  ALL_IN_ONE
  TABLET
  SMARTPHONE
  OTHER
}

enum TicketStatus {
  PENDING      // Aguardando análise
  QUOTED       // Orçamento enviado
  APPROVED     // Aprovado pelo cliente
  REJECTED     // Rejeitado pelo cliente
  IN_PROGRESS  // Em andamento
  WAITING_PART // Aguardando peça
  COMPLETED    // Concluído
  CANCELLED    // Cancelado
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketStatusHistory {
  id        String       @id @default(uuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  status    TicketStatus
  reason    String?
  changedAt DateTime     @default(now())
  
  @@index([ticketId])
  @@index([status])
}

// ============================================
// ORÇAMENTOS
// ============================================

model Quote {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  
  // Informações do serviço
  service     String
  description String
  price       Decimal  @db.Decimal(10, 2)
  
  // Status
  status      QuoteStatus @default(PENDING)
  
  // Timestamps
  createdAt   DateTime @default(now())
  approvedAt  DateTime?
  
  // Técnico que criou
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  
  @@index([ticketId])
  @@index([status])
}

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// SERVIÇOS E PEÇAS
// ============================================

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    ServiceCategory
  basePrice   Decimal  @db.Decimal(10, 2)
  minPrice    Decimal  @db.Decimal(10, 2)
  maxPrice    Decimal  @db.Decimal(10, 2)
  estimatedTime String // "1-2 dias", "2-4 horas"
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([isActive])
}

enum ServiceCategory {
  HARDWARE
  SOFTWARE
  MAINTENANCE
  UPGRADE
  ACCESSORY
}

model Part {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  brand       String?
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([isActive])
}

// ============================================
// CONFIGURAÇÕES E LOGS
// ============================================

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt
  
  @@index([key])
}

model SystemLog {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String
  context   Json?
  userId    String?
  createdAt DateTime @default(now())
  
  @@index([level])
  @@index([createdAt])
  @@index([userId])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}
