; NPM Configuration for EasyPanel
; Esta configuração otimiza o build do app em produção

; Usar lockfile-v2 (mais rápido)
lockfile-version=2

; Disable preflight scripts (mais rápido no deploy)
ignore-scripts=false

; Production flag
production=true

; Cache (otimizado)
cache-min=10

; Timeout aumentado (para builds lentos)
fetch-timeout=120000

; Progress bar (útil para debug)
progress=true
